# Neon Postgres pooled connection string
# https://neon.tech → project → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Stripe RESTRICTED, READ-ONLY secret key.
# Create at https://dashboard.stripe.com/apikeys → "Create restricted key".
# Grant READ access to: Products, Prices, Subscriptions, Invoices, Checkout Sessions.
STRIPE_SECRET_KEY="rk_live_xxx"

# Shared secret guarding the /api/cron/sync-revenue route.
# Generate any long random string, e.g. `openssl rand -hex 32`.
CRON_SECRET="change-me-to-a-long-random-string"

# Stripe webhook signing secret for /api/webhooks/stripe (the sale-tweet hook).
# Dashboard → Developers → Webhooks → your endpoint → "Signing secret".
# Locally, `stripe listen` prints a whsec_ to use instead.
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# X (Twitter) OAuth 1.0a creds for posting the "new sale" tweet.
# X Developer Portal → your app (Read+Write) → Keys and tokens.
# Leave unset to dry-run (the webhook logs the tweet instead of posting).
X_API_KEY="xxx"
X_API_SECRET="xxx"
X_ACCESS_TOKEN="xxx"
X_ACCESS_SECRET="xxx"
